# Supabase - required for data persistence
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...

# NVIDIA AI (optional - only for AI Studio image generation)
NVIDIA_API_KEY=nvapi-...

# NVIDIA NIM - local video container (optional)
# When set, the local-nim video provider appears in Studio Video tab.
# Local: http://localhost:8000   Brev: https://<instance>.brevdev.us/v1
# NVIDIA_NIM_BASE_URL=http://localhost:8000

# ComfyUI (optional - primary keyframe generator, NVIDIA API is fallback)
COMFYUI_BASE_URL=http://127.0.0.1:8188
COMFYUI_WORKFLOW=sdxl
COMFYUI_SDXL_CKPT=epicrealism_naturalSinRC1VAE.safetensors
# COMFYUI_WIDTH=768
# COMFYUI_HEIGHT=432
# COMFYUI_FLUX_CKPT=flux1-dev-fp8.safetensors
# COMFYUI_API_KEY=

# Admin UI login
NEXT_PUBLIC_ADMIN_UI_USERNAME=admin@mamazainab.com

# Auth - server-side only, never commit real values
ADMIN_EMAIL=admin@mamazainab.com
ADMIN_PASSWORD=your-secure-password-here
ART_DIRECTOR_EMAIL=art.director@mamazainab.com
ART_DIRECTOR_PASSWORD=your-secure-art-director-password-here
ADMIN_JWT_SECRET=generate-a-random-32-char-string-here
PARTNER_JWT_SECRET=generate-a-random-32-char-string-here

# Video generation providers (optional - Studio Video tab + Story Project shot gen)
# Runway Gen-4 Turbo (hero tier - production quality, ~$0.05/sec)
# RUNWAY_API_KEY=key_...
# RunPod (draft tier - WAN 2.2 endpoint, ~$0.004/sec)
# RUNPOD_API_KEY=...
# RUNPOD_WAN_ENDPOINT_ID=...
# fal.ai (hero tier - Kling, Luma, Veo, Pika, Wan via single API)
# FAL_KEY=...

# AWS Bedrock - Nova Reel video generation (~$0.06/clip, us-east-1)
# Local dev: credentials auto-loaded from ~/.aws/credentials (no keys needed here)
# Vercel: set AWS_ACCESS_KEY_ID + AWS_SECRET_ACCESS_KEY in dashboard
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# AWS_S3_BUCKET=your-bucket-name

# Brand private data - sensitive brand prose (char anchors, AI prompt templates, origin story)
# Loaded from data/brand-private.json in local dev (gitignored - generate with the script below).
# For Vercel: base64-encode the JSON file and paste here:
#   [Windows]  [Convert]::ToBase64String([System.Text.Encoding]::UTF8.GetBytes((Get-Content data\brand-private.json -Raw))) | clip
#   [macOS]    base64 -i data/brand-private.json | tr -d '\n' | pbcopy
# BRAND_PRIVATE_DATA=<base64-encoded-json>
