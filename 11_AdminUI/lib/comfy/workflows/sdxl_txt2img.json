{
  "_comment": "Universal SDXL/SD1.5 txt2img — works with any checkpoint. Placeholders __PROMPT__ __NEGATIVE__ __WIDTH__ __HEIGHT__ __SEED__ __CKPT__ are substituted by the client. Set COMFYUI_SDXL_CKPT env var to override the default checkpoint name.",
  "3": {
    "class_type": "KSampler",
    "inputs": {
      "seed": "__SEED__",
      "steps": 25,
      "cfg": 7,
      "sampler_name": "dpmpp_2m",
      "scheduler": "karras",
      "denoise": 1,
      "model": ["4", 0],
      "positive": ["6", 0],
      "negative": ["7", 0],
      "latent_image": ["5", 0]
    }
  },
  "4": {
    "class_type": "CheckpointLoaderSimple",
    "inputs": { "ckpt_name": "__CKPT__" }
  },
  "5": {
    "class_type": "EmptyLatentImage",
    "inputs": { "width": "__WIDTH__", "height": "__HEIGHT__", "batch_size": 1 }
  },
  "6": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__PROMPT__", "clip": ["4", 1] }
  },
  "7": {
    "class_type": "CLIPTextEncode",
    "inputs": { "text": "__NEGATIVE__", "clip": ["4", 1] }
  },
  "8": {
    "class_type": "VAEDecode",
    "inputs": { "samples": ["3", 0], "vae": ["4", 2] }
  },
  "9": {
    "class_type": "SaveImage",
    "inputs": { "filename_prefix": "mamazainab_kf", "images": ["8", 0] }
  }
}
