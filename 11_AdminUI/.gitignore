# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# private data - never commit to public repo
# real subscriber emails
data/contacts.json
# brand script, Falaha strategy, cinematic screenplay (business IP)
data/videos.json
# character IP - anchor blocks, AI prompts, reference image paths
data/characters.json
# AI generation history (ephemeral, large)
data/generations.json
# admin email, social handles
data/settings.json
# location strategy
data/branches.json
# partner portal config
data/partners.json
# sensitive brand prose: char anchors, AI prompt templates, origin story
data/brand-private.json
.pnpm-debug.log*

# runtime-generated uploads (too large / ephemeral for git)
public/uploads/menu-source/
public/uploads/generations/
public/uploads/keyframes/

# AI model weights - too large for git (164MB each)
../10_AI_Assets/

# env files
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
