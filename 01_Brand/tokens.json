{
  "$schema": "./tokens.schema.json",
  "meta": {
    "brand": "MaMa Zainab",
    "brandNameArabic": "ماما زينب",
    "brandNameChinese": "盛恒王",
    "version": "2026.05.0",
    "source": "Mama Zainab Brand_guideline.pdf (p.9) + pitch deck",
    "lastUpdated": "2026-05-03",
    "status": "draft-locked-colors-typography"
  },
  "color": {
    "brand": {
      "green": {
        "value": "#1B9B00",
        "rgb": [27, 155, 0],
        "cmyk": [83, 13, 100, 2],
        "role": "PRIMARY (base) \u2014 vine leaves, freshness, authenticity",
        "notes": "Promoted to plaid-pattern BASE (was yellow). Use for backgrounds, primary surfaces, kiosk facade, packaging base."
      },
      "yellow": {
        "value": "#EFD200",
        "rgb": [239, 210, 0],
        "cmyk": [8, 12, 100, 0],
        "role": "SECONDARY (accent) \u2014 warmth, generosity, mother's kitchen",
        "notes": "Demoted from base to accent. Use for highlights, CTAs, plaid stripes/checks, logo lockups, signage trim."
      },
      "black": {
        "value": "#000000",
        "rgb": [0, 0, 0],
        "cmyk": [75, 68, 67, 90],
        "role": "Strength, contrast, body text"
      },
      "white": {
        "value": "#FFFFFF",
        "rgb": [255, 255, 255],
        "cmyk": [0, 0, 0, 0],
        "role": "Cleanliness, breathing room, surface"
      }
    },
    "extended": {
      "greenDeep":   { "value": "#169216", "role": "Hover / dark variant of brand green (sampled from guideline)" },
      "cream":       { "value": "#F0F4EB", "role": "Warm off-white surface; alt to pure white" },
      "alertRed":    { "value": "#E60000", "role": "Disruption / 'STOP' campaign creative; errors. NOT for general UI." },
      "ink":         { "value": "#2C292A", "role": "Primary text on light surfaces (softer than #000)" },
      "mutedGrey":   { "value": "#B7B7B7", "role": "Disabled / dividers" }
    },
    "semantic": {
      "background":        { "$value": "{color.brand.white.value}" },
      "surface":           { "$value": "{color.extended.cream.value}" },
      "surfaceInverse":    { "$value": "{color.brand.green.value}" },
      "textPrimary":       { "$value": "{color.extended.ink.value}" },
      "textOnGreen":       { "$value": "{color.brand.white.value}" },
      "textOnYellow":      { "$value": "{color.brand.black.value}" },
      "actionPrimary":     { "$value": "{color.brand.green.value}" },
      "actionPrimaryHover":{ "$value": "{color.extended.greenDeep.value}" },
      "actionAccent":      { "$value": "{color.brand.yellow.value}" },
      "border":            { "$value": "{color.extended.mutedGrey.value}" },
      "danger":            { "$value": "{color.extended.alertRed.value}" }
    }
  },
  "typography": {
    "families": {
      "display":   { "value": "Chinese Monoline, serif",                "role": "Logo + hero display only",     "file": "fonts/Chinese Monoline.ttf" },
      "headline":  { "value": "'Bebas Neue', Impact, sans-serif",       "role": "Section headlines, posters",   "file": "Adobe Fonts (license required)" },
      "body":      { "value": "'Poppins', system-ui, sans-serif",       "role": "Body, UI, captions",           "file": "Adobe Fonts \u2014 fallback: Google Fonts Poppins" },
      "arabic":    { "value": "'Cairo', 'Tajawal', sans-serif",         "role": "Arabic body & headlines (RTL)","file": "Google Fonts (open-source)" },
      "script":    { "value": "'Lucida Handwriting', cursive",          "role": "Hand-signed accents (sparing)","file": "fonts/LHANDW.TTF" },
      "cjk":       { "value": "'Kozuka Gothic Pr6N', 'Noto Sans JP', sans-serif", "role": "Chinese name 盛恒王", "file": "fonts/KozGoPr6N-Regular.otf" }
    },
    "weights": { "light": 300, "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "scale": {
      "display":  { "size": "72px", "lineHeight": "1.05", "tracking": "-0.02em", "family": "display" },
      "h1":       { "size": "56px", "lineHeight": "1.1",  "tracking": "0",        "family": "headline" },
      "h2":       { "size": "40px", "lineHeight": "1.15", "tracking": "0",        "family": "headline" },
      "h3":       { "size": "28px", "lineHeight": "1.2",  "tracking": "0",        "family": "headline" },
      "lead":     { "size": "20px", "lineHeight": "1.5",  "tracking": "0",        "family": "body", "weight": "medium" },
      "body":     { "size": "16px", "lineHeight": "1.6",  "tracking": "0",        "family": "body", "weight": "regular" },
      "caption":  { "size": "13px", "lineHeight": "1.4",  "tracking": "0.02em",   "family": "body", "weight": "medium" },
      "overline": { "size": "12px", "lineHeight": "1.2",  "tracking": "0.12em",   "family": "headline", "transform": "uppercase" }
    }
  },
  "spacing": {
    "0": "0",     "1": "4px",   "2": "8px",   "3": "12px",  "4": "16px",
    "5": "24px",  "6": "32px",  "7": "48px",  "8": "64px",  "9": "96px", "10": "128px"
  },
  "radius": { "sm": "4px", "md": "8px", "lg": "16px", "pill": "999px" },
  "shadow": {
    "sm": "0 1px 2px rgba(0,0,0,.06), 0 1px 1px rgba(0,0,0,.04)",
    "md": "0 4px 12px rgba(0,0,0,.08)",
    "lg": "0 12px 32px rgba(0,0,0,.12)"
  },
  "pattern": {
    "plaid": {
      "base":   { "$value": "{color.brand.green.value}",   "note": "FLIPPED \u2014 green now base" },
      "stripe": { "$value": "{color.brand.yellow.value}" },
      "weft":   { "$value": "{color.brand.white.value}" },
      "ratio":  { "baseUnit": "16px", "stripe": 2, "weft": 1, "gap": 5 },
      "directions": ["horizontal", "vertical"],
      "blendMode": "multiply",
      "usage": "apron, packaging side panels, kiosk awning, web hero accents, app onboarding"
    }
  },
  "motion": {
    "duration": { "fast": "120ms", "base": "200ms", "slow": "320ms", "cinematic": "600ms" },
    "ease":     { "standard": "cubic-bezier(0.2,0,0,1)", "emphasized": "cubic-bezier(0.3,0,0,1)" }
  },
  "logo": {
    "lock": "TEXT_AND_FONT_ONLY",
    "wordmark": "MaMa Zainab",
    "wordmarkArabic": "ماما زينب",
    "wordmarkChinese": "盛恒王",
    "fontFamily": "Chinese Monoline (display)",
    "primaryMark": "TBD \u2014 mark/illustration not finalized",
    "spelling": { "approved": ["MaMa Zainab"], "rejected": ["MAMA ZAYNAB", "MAMA ZEINAB", "Mama Zeinab"] },
    "minSize": { "web": "120px wide", "print": "25mm wide" },
    "clearSpace": "1\u00d7 cap-height of 'M' on all sides"
  }
}
