# Supabase — required for data persistence
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# NVIDIA AI (optional — only for AI Studio video generation)
NVIDIA_API_KEY=nvapi-...

# Admin auth — server-side only, never commit real values
# Password for admin@mamazainab.com login
ADMIN_PASSWORD=your-secure-password-here
# Random secret for signing JWT session cookies (min 32 chars)
ADMIN_JWT_SECRET=generate-a-random-32-char-string-here
